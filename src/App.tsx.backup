const stageStorageKey = "memory-stage";
const albumViewStorageKey = "memory-album-view";
const albumSidebarVisibilityStorageKey = "memory-album-sidebar-visible";
const audioPlaybackTimeStorageKey = "memory-audio-time";
const audioPlaybackStateStorageKey = "memory-audio-state";
const photoSlotCount = 42;
const videoSlotCount = 6;

const createEmptySlots = (count: number): (AlbumItem | null)[] =>
  Array.from({ length: count }, () => null);

const createSlotKey = (kind: AlbumItem["kind"], slotIndex: number) => `${kind}-${slotIndex}`;

const readStoredStage = (): Stage => {
  if (typeof window === "undefined") return "flowers";

  const savedStage = window.localStorage.getItem(stageStorageKey);
  if (savedStage === "flowers" || savedStage === "letter" || savedStage === "album") {
    return savedStage;
  }

  return "flowers";
};

const readStoredAlbumView = (): AlbumView => {
  if (typeof window === "undefined") return "photos";

  const savedAlbumView = window.localStorage.getItem(albumViewStorageKey);
  return savedAlbumView === "videos" ? "videos" : "photos";
};

const readStoredAlbumSidebarVisible = (): boolean => {
  if (typeof window === "undefined") return true;

  const savedSidebarVisible = window.localStorage.getItem(albumSidebarVisibilityStorageKey);
  if (savedSidebarVisible === "false") return false;
  return true;
};

const formatMemoryLabel = (fileName: string, fallback: string) => {
  const withoutExtension = fileName.replace(/\.[^.]+$/, "");
  const normalized = withoutExtension.replace(/[_-]+/g, " ").replace(/\s+/g, " ").trim();

  if (!normalized) return fallback;

  const titleCased = normalized.replace(/\b\w/g, (character) => character.toUpperCase());
  return titleCased.length > 34 ? `${titleCased.slice(0, 31).trim()}...` : titleCased;
};

const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

const getCropGeometry = (
  imageWidth: number,
  imageHeight: number,
  zoom: number,
  offsetX: number,
  offsetY: number,
) => {
  const safeWidth = Math.max(imageWidth, 1);
  const safeHeight = Math.max(imageHeight, 1);
  const safeZoom = clamp(zoom, 1, 2);
  const cropSide = Math.min(safeWidth, safeHeight) / safeZoom;
  const maxShiftX = Math.max(0, (safeWidth - cropSide) / 2);
  const maxShiftY = Math.max(0, (safeHeight - cropSide) / 2);
  const normalizedX = clamp(offsetX / 100, -1, 1);
  const normalizedY = clamp(offsetY / 100, -1, 1);
  const sourceX = clamp((safeWidth - cropSide) / 2 + normalizedX * maxShiftX, 0, safeWidth - cropSide);
  const sourceY = clamp((safeHeight - cropSide) / 2 + normalizedY * maxShiftY, 0, safeHeight - cropSide);
  const previewWidthPercent = (safeWidth / cropSide) * 100;
  const previewHeightPercent = (safeHeight / cropSide) * 100;
  const previewShiftXPercent = (-normalizedX * Math.max(previewWidthPercent - 100, 0)) / 2;
  const previewShiftYPercent = (-normalizedY * Math.max(previewHeightPercent - 100, 0)) / 2;

  return {
    cropSide,
    sourceX,
    sourceY,
    previewWidthPercent,
    previewHeightPercent,
    previewShiftXPercent,
    previewShiftYPercent,
  };
};

