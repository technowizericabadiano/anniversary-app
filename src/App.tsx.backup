type Stage = "flowers" | "letter" | "album";
type AlbumView = "photos" | "videos";

type BouquetFlower = {
  id: string;
  x: number;
  y: number;
  scale: number;
  stemPath: string;
  stemThickness?: number;
  outerGradient: string;
  innerGradient: string;
  bloomGlow: string;
  centerColor: string;
  dotColor: string;
  outerPetalCount: number;
  innerPetalCount: number;
  outerPetalRx: number;
  outerPetalRy: number;
  innerPetalRx: number;
  innerPetalRy: number;
  outerAngleOffset?: number;
  innerAngleOffset?: number;
  isBackFlower?: boolean;
  sway: [number, number, number];
  swayDuration: number;
  leaves: {
    cx: number;
    cy: number;
    rx: number;
    ry: number;
    rotation: number;
    gradient: string;
  }[];
};

type AccentSprig = {
  id: string;
  path: string;
  blossoms: {
    x: number;
    y: number;
    scale: number;
  }[];
};

type DriftingPetal = {
  id: string;
  left: string;
  top: string;
  duration: number;
  delay: number;
  rotate: number;
};

type FallingPetal = {
  id: string;
  left: string;
  width: number;
  height: number;
  duration: number;
  delay: number;
  drift: number;
  rotate: number;
  opacity: number;
  blur?: number;
};

export type AlbumItem = {
  id: string;
  url: string;
  name: string;
  label: string;
  kind: "image" | "video";
  mimeType: string;
};

const heartSymbol = "\u2764\uFE0F";
const cameraSymbol = "\u{1F4F8}";
const videoSymbol = "\u{1F4F9}";

const letterTitle = "Happy 3rd Anniversary, Babe";

const letterText = [
  letterTitle,
  "",
  "Babe, it has been three beautiful years since we started this journey together, and I still cannot believe how lucky I am to have you in my life. These past three years have been filled with love, laughter, growth, and unforgettable memories that I will always treasure in my heart.",
  "",
  "From the very beginning, you changed my world in the most beautiful way. You brought light into my life when I did not even realize I needed it. Every time you smile, every time you laugh, and every time you say my name, my heart feels so full. Loving you has been the most natural and happiest part of my life.",
  "",
  "Babe, thank you for staying with me through everything. Through the good days and the hard ones, through misunderstandings and challenges, we always chose each other. That is what makes our love so special. We did not just fall in love, we grew in love. We learned, we adjusted, and we became stronger together.",
  "",
  "You are not just my girlfriend. You are my best friend, my comfort, my peace, and my greatest blessing. When I am with you, I feel safe. When I am with you, I feel understood. When I am with you, I feel at home.",
  "",
  "Three years may sound like just a number, but for me it represents countless memories, the sweet messages, the random jokes, and the simple moments that became unforgettable because I shared them with you. Every second with you is something I truly treasure.",
  "",
  "Babe, my love for you keeps growing every single day. It is deeper, stronger, and more certain than ever. I promise to keep choosing you, to keep loving you, to keep supporting you, and to keep building a future with you. This is only the beginning of our forever.",
  "",
  "Happy 3rd Anniversary, Babe. Thank you for loving me, for believing in us, and for being the most amazing person in my life. I love you more than words can ever express, today, tomorrow, and always.",
].join("\n");

const letterBodyText = letterText.startsWith(`${letterTitle}\n\n`)
  ? letterText.slice(letterTitle.length + 2)
  : letterText;

const splitLetterParagraphs = (text: string) =>
  text
    .split(/\n\s*\n/)
    .map((paragraph) => paragraph.trim())
    .filter(Boolean);

